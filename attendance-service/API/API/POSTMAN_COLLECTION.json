  "item": [
    {
      "name": "Attendance APIs",
      "item": [
        {
          "name": "Check-In",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "https://localhost:7108/api/attendance/check-in?employeeId=ccfe9ea4-f0f6-4356-84e9-9bc97072a9b8&shiftId=1",
              "protocol": "https",
              "host": ["localhost"],
              "port": "7108",
              "path": ["api", "attendance", "check-in"],
              "query": [
                {
                  "key": "employeeId",
                  "value": "ccfe9ea4-f0f6-4356-84e9-9bc97072a9b8",
                  "description": "Employee ID (UUID)"
                },
                {
                  "key": "shiftId",
                  "value": "1",
                  "description": "Shift ID (optional, default=1=Morning)"
                }
              ]
            },
            "description": "Record employee check-in time and calculate if late"
          },
          "response": []
        },
        {
          "name": "Check-Out",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "https://localhost:7108/api/attendance/check-out?employeeId=ccfe9ea4-f0f6-4356-84e9-9bc97072a9b8",
              "protocol": "https",
              "host": ["localhost"],
              "port": "7108",
              "path": ["api", "attendance", "check-out"],
              "query": [
                {
                  "key": "employeeId",
                  "value": "ccfe9ea4-f0f6-4356-84e9-9bc97072a9b8"
                }
              ]
            },
            "description": "Record employee check-out time and calculate working hours/overtime"
          },
          "response": []
        },
        {
          "name": "Get Attendance History",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://localhost:7108/api/attendance/history/ccfe9ea4-f0f6-4356-84e9-9bc97072a9b8?year=2026&month=6",
              "protocol": "https",
              "host": ["localhost"],
              "port": "7108",
              "path": ["api", "attendance", "history", "ccfe9ea4-f0f6-4356-84e9-9bc97072a9b8"],
              "query": [
                {
                  "key": "year",
                  "value": "2026",
                  "description": "Year (optional)"
                },
                {
                  "key": "month",
                  "value": "6",
                  "description": "Month 1-12 (optional)"
                }
              ]
            },
            "description": "Get detailed attendance history for an employee"
          },
          "response": []
        },
        {
          "name": "Get Monthly Summary (FOR PAYROLL)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://localhost:7108/api/attendance/monthly-summary/ccfe9ea4-f0f6-4356-84e9-9bc97072a9b8?month=6&year=2026",
              "protocol": "https",
              "host": ["localhost"],
              "port": "7108",
              "path": ["api", "attendance", "monthly-summary", "ccfe9ea4-f0f6-4356-84e9-9bc97072a9b8"],
              "query": [
                {
                  "key": "month",
                  "value": "6",
                  "description": "Month 1-12"
                },
                {
                  "key": "year",
                  "value": "2026",
                  "description": "Year"
                }
              ]
            },
            "description": "🔴 P0 CRITICAL - Get aggregated monthly attendance data (workingDays, leaveDays, overtimeHours, lateMinutes)\nUsed by Payroll to calculate salaries"
          },
          "response": []
        },
        {
          "name": "Get Leave Summary (FOR PAYROLL)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
