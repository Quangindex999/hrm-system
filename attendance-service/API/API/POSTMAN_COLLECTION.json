    {
      "name": "Leave APIs",
      "item": [
        {
          "name": "Get Employees for Leave",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://localhost:7108/api/leave/employees",
              "protocol": "https",
              "host": ["localhost"],
              "port": "7108",
              "path": ["api", "leave", "employees"]
            },
            "description": "Get list of active employees to select for leave request creation"
          },
          "response": []
        },
        {
          "name": "Create Leave Request",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employeeId\": \"ccfe9ea4-f0f6-4356-84e9-9bc97072a9b8\",\n  \"startDate\": \"2026-06-15T00:00:00Z\",\n  \"endDate\": \"2026-06-17T00:00:00Z\",\n  \"reason\": \"Medical appointment\"\n}"
            },
            "url": {
              "raw": "https://localhost:7108/api/leave/request",
              "protocol": "https",
              "host": ["localhost"],
              "port": "7108",
              "path": ["api", "leave", "request"]
            },
            "description": "Create a new leave request"
          },
          "response": []
        },
        {
          "name": "Get Pending Leave Requests",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://localhost:7108/api/leave/pending-list",
              "protocol": "https",
              "host": ["localhost"],
              "port": "7108",
              "path": ["api", "leave", "pending-list"]
            },
            "description": "Get all pending leave requests (for managers to approve/reject)"
          },
          "response": []
        },
        {
          "name": "Get Employee Leave Requests",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://localhost:7108/api/leave/employee/ccfe9ea4-f0f6-4356-84e9-9bc97072a9b8",
              "protocol": "https",
              "host": ["localhost"],
              "port": "7108",
              "path": ["api", "leave", "employee", "ccfe9ea4-f0f6-4356-84e9-9bc97072a9b8"]
            },
            "description": "Get all leave requests for a specific employee"
          },
          "response": []
        },
        {
          "name": "Approve Leave Request",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"leaveRequestId\": \"<leave-request-id>\",\n  \"approverId\": \"<approver-employee-id>\",\n  \"notes\": \"Approved\"\n}"
            },
            "url": {
              "raw": "https://localhost:7108/api/leave/approve/<leave-request-id>",
              "protocol": "https",
              "host": ["localhost"],
              "port": "7108",
              "path": ["api", "leave", "approve", "<leave-request-id>"]
            },
            "description": "Approve a pending leave request (updates AttendanceLog to mark days as OnLeave)"
          },
          "response": []
        },
        {
          "name": "Reject Leave Request",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"leaveRequestId\": \"<leave-request-id>\",\n  \"approverId\": \"<rejector-employee-id>\",\n  \"notes\": \"Rejected - insufficient justification\"\n}"
            },
            "url": {
              "raw": "https://localhost:7108/api/leave/reject/<leave-request-id>",
              "protocol": "https",
              "host": ["localhost"],
              "port": "7108",
              "path": ["api", "leave", "reject", "<leave-request-id>"]
            },
            "description": "Reject a pending leave request"
          },
          "response": []
        }
      ]
    },
