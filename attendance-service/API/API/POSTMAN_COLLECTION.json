                {
                  "key": "month",
                  "value": "6",
                  "description": "Month 1-12"
                },
                {
                  "key": "year",
                  "value": "2026",
                  "description": "Year"
                }
              ]
            },
            "description": "🔴 P0 CRITICAL - Get leave summary with approved/pending/rejected requests\nUsed by Payroll to calculate leave deductions"
          },
          "response": []
        },
